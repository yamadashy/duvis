{
  "name": "duvis-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Browser UI for the duvis CLI. Built into a single HTML file embedded in the Rust binary.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prebuilt": "npm run build && node scripts/copy-to-prebuilt.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-hierarchy": "^3.1.2",
    "d3-shape": "^3.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/d3-array": "^3.2.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-shape": "^3.1.8",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  }
}

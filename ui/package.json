{
  "name": "duvis-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Browser UI for the duvis CLI. Built into a single HTML file embedded in the Rust binary.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prebuilt": "npm run build && node scripts/copy-to-prebuilt.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-hierarchy": "^3.1.2",
    "d3-shape": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/d3-array": "^3.2.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-shape": "^3.1.8",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
